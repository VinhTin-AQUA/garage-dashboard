{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "enables the default permissions",
    "windows": ["main"],
    "permissions": [
        "core:default",
        "fs:allow-stat",
        "fs:allow-read-text-file",
        "fs:allow-resource-read-recursive",
        {
            "identifier": "fs:scope",
            "allow": ["$RESOURCE/**/*"]
        }
    ]
}
